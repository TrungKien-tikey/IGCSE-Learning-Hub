    { "key": "comm_base", "value": "http://localhost:8086" },
    { "key": "ai_base", "value": "http://localhost:8087" },
    { "key": "access_token", "value": "" },
    { "key": "refresh_token", "value": "" },
    { "key": "reset_password_token", "value": "" },
    { "key": "logged_out_access_token", "value": "" },
    { "key": "user_email", "value": "" },
    { "key": "user_role", "value": "" }
  ]
}
